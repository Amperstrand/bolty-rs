# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly text files
*.rs text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.pdf binary
*.bin binary
*.elf binary
